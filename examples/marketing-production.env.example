# Copy this file to marketing-production.env and replace every placeholder with live values.
# Do not commit the copied marketing-production.env file.

# GTM web container loaded by the storefront SDK.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Browser endpoint for CRM/event automation capture.
NEXT_PUBLIC_CRM_WEBHOOK_URL=/api/crm/events

# Public production storefront URL used for GA4 web streams, ad landing pages, Meta domain verification, and CRM CORS.
NEXT_PUBLIC_APP_URL=https://your-store.example

# First-party delivery gateway called by the server receiver.
DOWNSTREAM_CRM_WEBHOOK_URL=https://your-store.example/api/crm/downstream

# Optional downstream provider auth. Keep the real value secret.
DOWNSTREAM_CRM_API_KEY=replace-with-crm-api-key-at-least-24-characters

# Test mode allows delivery only to exact recipients listed here. Change to live only after provider QA.
CRM_DELIVERY_MODE=test
CRM_TEST_RECIPIENTS=test@example.com,01012345678

# Durable idempotency and cancellation index for scheduled abandonment messages.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# Email delivery via Resend. The sender domain must be verified before live delivery.
RESEND_API_KEY=re_replace-with-resend-key
RESEND_FROM_EMAIL=Store <hello@your-domain.example>

# Kakao Brand Message delivery via SOLAPI.
SOLAPI_API_KEY=replace-with-solapi-key
SOLAPI_API_SECRET=replace-with-solapi-secret
SOLAPI_KAKAO_PF_ID=replace-with-kakao-profile-id
SOLAPI_KAKAO_TARGETING=I

# Default ecommerce currency for dataLayer and CRM events.
NEXT_PUBLIC_MARKETING_DEFAULT_CURRENCY=KRW

# GTM variable replacements used for GA4 and ad conversion tags.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=replace-with-purchase-label
NEXT_PUBLIC_META_PIXEL_ID=replace-with-meta-pixel-id
